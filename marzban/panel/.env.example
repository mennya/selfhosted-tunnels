UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

# JWT secret — generate with: openssl rand -hex 32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
SECRET_KEY=change_me_openssl_rand_hex_32

# SQLite (default, fine for personal use)
SQLALCHEMY_DATABASE_URL=sqlite:////var/lib/marzban/db.sqlite3

# Uncomment for MariaDB:
# SQLALCHEMY_DATABASE_URL=mariadb+pymysql://marzban:password@mariadb/marzban

# Xray core config path (mounted inside container)
XRAY_JSON=/var/lib/marzban/xray_config.json

# Optional: Telegram bot for user management
# TELEGRAM_API_TOKEN=
# TELEGRAM_ADMIN_ID=

# Optional: custom subscription base URL (if behind a domain)
# SUBSCRIPTION_URL_PREFIX=https://your-domain.com
