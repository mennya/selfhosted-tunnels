TZ=Europe/Amsterdam

# Public IP of this server — used to bind ports to the correct interface
# (avoids conflicts with Tailscale or other services also using port 443)
SERVER_IP=1.2.3.4

UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

# JWT secret — generate with: openssl rand -hex 32
SECRET_KEY=change_me_openssl_rand_hex_32

# SQLite (default, fine for personal use)
SQLALCHEMY_DATABASE_URL=sqlite:////var/lib/marzban/db.sqlite3

XRAY_JSON=/var/lib/marzban/xray_config.json

# SSL — required for panel to bind to 0.0.0.0 (otherwise stays on 127.0.0.1)
# Generate with: see README → SSL setup
UVICORN_SSL_CERTFILE=/var/lib/marzban/certs/cert.pem
UVICORN_SSL_KEYFILE=/var/lib/marzban/certs/key.pem
UVICORN_SSL_CA_TYPE=selfsigned
