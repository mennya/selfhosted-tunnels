# Address/IP this node listens on (used for panel ↔ node TLS)
SERVICE_ADDRESS=your-local-public-ip-or-domain

SERVICE_PORT=62050
XRAY_API_PORT=62051

# TLS certificate from the Marzban panel
# Get it from: panel Settings → Nodes → Show Certificate
# Paste the full -----BEGIN CERTIFICATE----- block
SSL_CLIENT_CERT_FILE=/var/lib/marzban-node/ssl_client_cert.pem
